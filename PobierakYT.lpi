<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <Flags>
        <SaveOnlyProjectUnits Value="True"/>
      </Flags>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="PobierakYT"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
